// Сгенерировано generate_prisma_schema.py — не править вручную.
// Источник: specs/sql/mapping.json + specs/prisma/mapping.json

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Одна строка = одна строка JSONL (одно свидетельство).
model Certificate {
  source_file String @db.Text
  certificate_id String @db.Text
  is_federal Boolean?
  status_name String? @db.Text
  type_name String? @db.Text
  region_name String? @db.Text
  region_code String? @db.Text
  federal_district_name String? @db.Text
  federal_district_short_name String? @db.Text
  reg_number String? @db.Text
  serial_number String? @db.Text
  form_number String? @db.Text
  issue_date String? @db.Text
  end_date String? @db.Text
  control_organ String? @db.Text
  post_address String? @db.Text
  edu_org_full_name String? @db.Text
  edu_org_short_name String? @db.Text
  edu_org_inn String? @db.Text
  edu_org_kpp String? @db.Text
  edu_org_ogrn String? @db.Text
  individual_entrepreneur_last_name String? @db.Text
  individual_entrepreneur_first_name String? @db.Text
  individual_entrepreneur_middle_name String? @db.Text
  individual_entrepreneur_address String? @db.Text
  individual_entrepreneur_egrip String? @db.Text
  individual_entrepreneur_inn String? @db.Text
  supplements Supplement[]
  decisions Decision[]
  actual_education_organizations ActualEducationOrganization[] @relation("AeoViaCertificate")
  @@id([source_file, certificate_id])
  @@map("certificates")
}

/// Элементы массива JSON Supplements (вложенные объекты без обёртки Supplement в JSON — см. convert.py).
model Supplement {
  source_file String @db.Text
  certificate_id String @db.Text
  supplement_id String @db.Text
  status_name String? @db.Text
  status_code String? @db.Text
  number String? @db.Text
  serial_number String? @db.Text
  form_number String? @db.Text
  issue_date String? @db.Text
  is_for_branch Boolean?
  note String? @db.Text
  edu_org_full_name String? @db.Text
  edu_org_short_name String? @db.Text
  edu_org_address String? @db.Text
  edu_org_kpp String? @db.Text
  certificate Certificate @relation(fields: [source_file, certificate_id], references: [source_file, certificate_id], onDelete: Cascade)
  educational_programs EducationalProgram[]
  actual_education_organizations ActualEducationOrganization[] @relation("AeoViaSupplement")
  @@id([source_file, certificate_id, supplement_id])
  @@map("supplements")
}

/// Распорядительные документы: по одной строке на элемент Decisions[] с непустым Id в JSONL. Элементы с пустым Id не импортируются (нет ключа документа); сертификат и организация из той же строки JSONL не отбрасываются.
model Decision {
  source_file String @db.Text
  certificate_id String @db.Text
  decision_id String @db.Text
  decision_type_name String? @db.Text
  order_document_number String? @db.Text
  order_document_kind String? @db.Text
  decision_date String? @db.Text
  certificate Certificate @relation(fields: [source_file, certificate_id], references: [source_file, certificate_id], onDelete: Cascade)
  @@id([source_file, certificate_id, decision_id])
  @@map("decisions")
}

/// Программы внутри каждого элемента Supplements (массив EducationalPrograms). Идентификатор программы в реестре (program_id) может повторяться для разных периодов/строк выгрузки; уникальность строки задаёт program_slot — порядковый индекс элемента в массиве EducationalPrograms данного приложения (0, 1, …).
model EducationalProgram {
  source_file String @db.Text
  certificate_id String @db.Text
  supplement_id String @db.Text
  program_slot Int
  program_id String? @db.Text
  type_name String? @db.Text
  edu_level_name String? @db.Text
  programm_name String? @db.Text
  programm_code String? @db.Text
  ugs_name String? @db.Text
  ugs_code String? @db.Text
  edu_normative_period String? @db.Text
  qualification String? @db.Text
  is_accredited Boolean?
  is_canceled Boolean?
  is_suspended Boolean?
  supplement Supplement @relation(fields: [source_file, certificate_id, supplement_id], references: [source_file, certificate_id, supplement_id], onDelete: Cascade)
  @@id([source_file, certificate_id, supplement_id, program_slot])
  @@map("educational_programs")
}

/// Вложенный объект ActualEducationOrganization: либо на корне сертификата, либо внутри элемента Supplements. Различие по ae_scope и nullable supplement_id. Если aeo_id на корне (ae_scope=certificate) и aeo_id во вложенной строке (ae_scope=supplement) для одной строки JSONL различаются, в типичном случае это означает филиал: приложение привязано к отдельной ОО (часто филиалу), карточка на корне — к головной/основной организации; дополнительно см. поле is_branch.
model ActualEducationOrganization {
  source_file String @db.Text
  certificate_id String @db.Text
  ae_scope String @db.Text
  supplement_id String @db.Text
  aeo_id String @db.Text
  full_name String? @db.Text
  short_name String? @db.Text
  head_edu_org_id String? @db.Text
  is_branch Boolean?
  post_address String? @db.Text
  phone String? @db.Text
  fax String? @db.Text
  email String? @db.Text
  web_site String? @db.Text
  ogrn String? @db.Text
  inn String? @db.Text
  kpp String? @db.Text
  head_post String? @db.Text
  head_name String? @db.Text
  form_name String? @db.Text
  kind_name String? @db.Text
  type_name String? @db.Text
  region_name String? @db.Text
  federal_district_short_name String? @db.Text
  federal_district_name String? @db.Text
  certificate Certificate @relation("AeoViaCertificate", fields: [source_file, certificate_id], references: [source_file, certificate_id], onDelete: Cascade)
  supplement Supplement? @relation("AeoViaSupplement", fields: [source_file, certificate_id, supplement_id], references: [source_file, certificate_id, supplement_id], onDelete: Cascade)
  @@id([source_file, certificate_id, ae_scope, supplement_id, aeo_id])
  @@map("actual_education_organizations")
}
