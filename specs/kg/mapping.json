            "ProgrammName",
            "ProgrammCode",
            "UGSName",
            "UGSCode",
            "EduNormativePeriod",
            "Qualification",
            "IsAccredited",
            "IsCanceled",
            "IsSuspended"
          ],
          "note_ru": "EduLevelName вынесен в узел EducationalLevel (см. node_kinds EducationalLevel и рёбра hasEducationLevel / offersEducationLevel); в JSON ключ остаётся."
        }
      ]
    },
    {
      "kind": "EducationalLevel",
      "description_ru": "Уровень образования (уникальный текст EduLevelName). Глобальный URI: urn:accred:v1:EducationalLevel:<64 hex SHA-256 от UTF-8 строки имени после trim>. На узле свойство name — тот же текст.",
      "id_template": "urn:accred:v1:EducationalLevel:{sha256_utf8_EduLevelName}",
      "id_fields": [
        "EduLevelName"
      ],
      "scalar_property_groups": [
        {
          "group": "level_display",
          "description_ru": "Импортёры задают name из EduLevelName.",
          "json_keys": []
        }
      ]
    },
    {
      "kind": "Region",
      "description_ru": "Регион (текст RegionName с сертификата или с карточки ОО). URI: urn:accred:v1:Region:<64 hex SHA-256 от UTF-8 строки после trim>. Свойство name — исходная строка.",
      "id_template": "urn:accred:v1:Region:{sha256_utf8_RegionName}",
      "id_fields": [
        "RegionName"
      ],
      "scalar_property_groups": [
        {
          "group": "region_display",
          "description_ru": "Импортёры задают name из RegionName.",
          "json_keys": []
        }
      ]
    },
    {
      "kind": "ActualEducationOrganization",
      "description_ru": "Карточка образовательной организации (вложенный объект). Идентификатор узла в графе — по шаблону AEO (не по ОГРН); свойство OGRN и др. остаётся на узле для связей и сверки по реестру. Узлы с разными AEO.Id в scope certificate и supplement в одной строке JSONL типично соответствуют головной организации и филиалу (отдельная ОО в приложении).",
      "id_template": "urn:accred:v1:AEO:{certificate_Id}:{scope}:{AEO.Id}",
      "id_fields": [
        "Id",
        "scope",
        "ActualEducationOrganization.Id"
      ],
      "scope_values": [
        {
          "value": "certificate",
          "json_path": "ActualEducationOrganization",
          "parent_kind": "Certificate"
        },
        {
          "value": "supplement",
          "json_path": "Supplements[].ActualEducationOrganization",
          "parent_kind": "Supplement"
        }
      ],
      "scalar_property_groups": [
        {
          "group": "aeo_core",
          "json_keys": [
            "FullName",
            "ShortName",
            "HeadEduOrgId",
            "IsBranch",
            "PostAddress",
            "Phone",
            "Fax",
            "Email",
            "WebSite",
            "OGRN",
            "INN",
            "KPP",
            "HeadPost",
            "HeadName",
            "FormName",
            "KindName",
            "TypeName",
            "FederalDistrictShortName",
            "FederalDistrictName"
          ],
          "note_ru": "RegionName вынесен в узел Region (ребро inRegion); в JSON ключ остаётся. OGRN/INN и др. остаются на узле ОО."
        }
      ]
    }
  ],
