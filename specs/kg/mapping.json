  "description_ru": "Описание узлов и рёбер для построения property graph или RDF из строк JSONL конвертера. Идентификаторы — шаблоны: подставляйте значения из той же строки JSON; при коллизиях добавляйте версию снимка.",
  "id_conventions": {
    "namespace": "urn:accred:v1:",
    "rules": [
      "Все глобальные URI строить из состава: namespace + kind + ':' + устойчивый локальный ключ.",
      "Локальный ключ сертификата: basename(_source_file) + ':' + строковое значение поля Id.",
      "Дочерние сущности включают в ключ идентификатор родителя, чтобы Id внутри приложения не путался между сертификатами."
    ]
  },
