    {
      "kind": "Decision",
      "description_ru": "Распорядительный документ. Узел в графе задаётся только при непустом Decisions[].Id; при пустом Id объект в JSONL может быть без устойчивого IRI — узел Certificate и данные об организации из строки остаются валидными.",
      "id_template": "urn:accred:v1:Decision:{certificate_Id}:{Decision.Id}",
      "id_fields": [
        "Id",
        "Decisions[].Id"
      ],
      "json_container": "Decisions",
      "item_key": "Decision",
      "scalar_property_groups": [
        {
          "group": "decision_core",
          "json_keys": [
            "DecisionTypeName",
            "OrderDocumentNumber",
            "OrderDocumentKind",
            "DecisionDate"
          ]
        }
      ]
    },
    {
      "kind": "EducationalProgram",
      "description_ru": "Образовательная программа внутри приложения. В шаблоне program_slot — порядковый индекс элемента в EducationalPrograms[] данного Supplement (0, 1, …), т.к. Id программы в реестре может повторяться для разных периодов.",
      "id_template": "urn:accred:v1:EducationalProgram:{certificate_Id}:{supplement_Id}:{program_slot}:{EducationalProgram.Id}",
      "id_fields": [
        "Id",
        "Supplements[].Id",
        "program_slot",
        "EducationalPrograms[].Id"
      ],
      "json_path": "Supplements[].EducationalPrograms[]",
      "scalar_property_groups": [
