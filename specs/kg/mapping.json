{
  "format_version": 1,
  "source_profile": "jsonl_one_object_per_line_root_equals_certificate_record",
  "description_ru": "Описание узлов и рёбер для построения property graph или RDF из строк JSONL конвертера. Идентификаторы — шаблоны по цепочке JSON Id (имя файла выгрузки в JSONL не входит); при слиянии разных снимков с одинаковыми Id возможны коллизии IRI — добавляйте внешний префикс снимка на стороне пайплайна.",
  "id_conventions": {
    "namespace": "urn:accred:v1:",
    "rules": [
      "Все глобальные URI строить из состава: namespace + kind + ':' + устойчивый локальный ключ.",
      "Локальный ключ сертификата: строковое значение поля Id на корне строки JSONL.",
      "Дочерние сущности включают в ключ идентификатор родителя, чтобы Id внутри приложения не путался между сертификатами.",
      "Узел EducationalProgram: в локальный ключ входят supplement Id и program_slot (0, 1, … по порядку в EducationalPrograms[]) и Id программы в реестре — одинаковый реестровый Id у нескольких строк массива нормален (разные периоды аккредитации)."
    ]
  },
  "node_kinds": [
    {
      "kind": "Certificate",
      "description_ru": "Свидетельство (корень объекта в строке JSONL)",
      "id_template": "urn:accred:v1:Certificate:{Id}",
      "id_fields": [
        "Id"
      ],
      "scalar_property_groups": [
