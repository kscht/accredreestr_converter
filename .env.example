# Скопируйте в `.env` в корне репозитория (`.env` в `.gitignore`).

# IP-адрес хоста для биндинга портов (docker compose + локальный запуск).
# Все сервисы (SurrealDB, API, Web, Postgres) слушают на этом адресе на хосте.
# Внутри контейнеров всегда 0.0.0.0 — переопределяется через environment:.
BIND_IP=127.2.0.1

# OpenRouter (`tools/draft_org_name_dictionary_openrouter.py`):
# OPENROUTER_API_KEY=sk-or-v1-...
